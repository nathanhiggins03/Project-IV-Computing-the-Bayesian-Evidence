mixture_density <- function(x, omega, mu, sigma) {
  
  S <- nrow(omega)
  K <- ncol(omega)
  M <- length(x)
  
  dens <- matrix(0, nrow = S, ncol = M)
  
  for (k in 1:K) {
    
    # Create S x M matrix of component densities
    comp_dens <- sapply(1:S, function(s)
      dnorm(x, mean = mu[s, k], sd = sigma[s, k])
    )
    
    comp_dens <- t(comp_dens)   
    
    dens <- dens + omega[, k] * comp_dens
  }
  
  colMeans(dens)
}

